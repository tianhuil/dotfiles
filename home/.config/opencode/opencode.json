{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{file:~/.config/opencode/context7-api-key}"
      },
      "enabled": true,
      "timeout": 5000
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true,
      "timeout": 5000
    },
    "serena": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena-mcp-server",
        "--enable-web-dashboard",
        "False"
      ],
      "enabled": true,
      "timeout": 5000
    },

    "webfetch_camouflage": {
      "type": "local",
      "command": [
        "uvx",
        "git+https://github.com/tianhuil/webfetch-camouflage-mcp.git"
      ],
      "enabled": true,
      "timeout": 10000
    }
  },
  "permission": {
    "external_directory": {
      "/tmp/**": "allow",
      "~/.config/opencode/opencode.json": "allow",
      "~/.config/opencode/AGENTS.md": "allow",
      "~/.config/opencode/agents/**": "allow",
      "~/.config/opencode/commands/**": "allow",
      "~/.config/opencode/skills/**": "allow"
    },
    "edit": {
      "/tmp/**": "allow",
      "~/.config/opencode/**": "deny"
    }
  },
  "tools": {
    "context7": true,
    "gh_grep": true,
    "serena": true,
    "webfetch_camouflage": false
  }
}
