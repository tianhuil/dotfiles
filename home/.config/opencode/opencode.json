{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "sequential_thinking": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "@wemake.cx/sequential-thinking@latest"
      ],
      "enabled": true,
      "timeout": 5000
    },
    "web-search-prime": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/web_search_prime/mcp",
      "headers": {
        "Authorization": "Bearer {file:~/.config/opencode/zai-api-key}"
      },
      "enabled": true,
      "timeout": 10000
    }
  },
  "permission": {
    "external_directory": {
      "/tmp/**": "allow",
      "~/.config/opencode/opencode.json": "allow",
      "~/.config/opencode/AGENTS.md": "allow",
      "~/.config/opencode/agents/**": "allow",
      "~/.config/opencode/commands/**": "allow",
      "~/.config/opencode/skills/**": "allow"
    },
    "bash": {
      "bash ~/.config/opencode/skills/**": "allow"
    },
    "edit": {
      "/tmp/**": "allow",
      "~/.config/opencode/**": "deny"
    }
  },
  "plugin": [
    "@0xsero/open-queue"
  ],
  "tools": {
    "context7": true,
    "sequential_thinking": true,
    "web_search_prime": true
  }
}
